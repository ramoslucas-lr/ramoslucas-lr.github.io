---
import Layout from '../layouts/Layout.astro';
import BentoBox from '../components/BentoBox.astro';
import { getCollection } from 'astro:content';

const photoEntries = await getCollection('photography');
// Pega apenas ensaios COM data, ordenados do mais recente para o mais antigo
const latestPhoto = photoEntries
  .filter(e => e.data.date)
  .sort((a, b) => b.data.date!.valueOf() - a.data.date!.valueOf())[0];

const dataEntries = await getCollection('data-engineering');
const latestDataProject = dataEntries[0];

const diceEntries = await getCollection('dice-awards');
const latestDice = diceEntries[0];

const academicEntries = await getCollection('academic');
const latestAcademic = academicEntries[0];
---

<Layout title="Lucas Ramos | Portfolio">
  <h1 class="sr-only">Lucas Ramos</h1>

  <main>
    <div class="bento-grid">
      
      <!-- Welcome / About Box -->
      <BentoBox spanCol="col-span-4 md:col-span-2" spanRow="row-span-2" glowColor="cyan" href="/about" className="flex flex-col justify-end group">
        <div class="absolute inset-0 bg-gradient-to-br from-surface to-base opacity-50 group-hover:opacity-30 transition-opacity"></div>
        <div class="relative z-10">
          <span class="font-mono text-xs text-neonLime tracking-widest mb-3 block">✦ lucasramos.dev</span>
          <h2 class="text-2xl font-bold mb-4 pt-only">oi, eu sou o <span class="text-neonLime">Lucas</span>.</h2>
          <h2 class="text-2xl font-bold mb-4 en-only">hi, I'm <span class="text-neonLime">Lucas</span>.</h2>
          <h2 class="text-2xl font-bold mb-4 fr-only">salut, je suis <span class="text-neonLime">Lucas</span>.</h2>
          
          <div class="text-textMuted text-sm mb-6 space-y-3 pt-only">
            <p>Esse é o meu cantinho da internet. Aqui do lado tem as <span class="text-neonLime/80">fotos</span> que eu não sinto vergonha de compartilhar e abaixo tem os <span class="text-neonLime/80">artigos</span> que me forço tanto a escrever quanto a postar.</p>
            <p>Não sei como você parou aqui, mas não espalha: se eu tiver muitos acessos começo a pagar o armazenamento das fotos.</p>
          </div>
          <div class="text-textMuted text-sm mb-6 space-y-3 en-only">
            <p>This is my little corner of the internet. Over there are the <span class="text-neonLime/80">photos</span> I'm not embarrassed to share, and below are the <span class="text-neonLime/80">articles</span> I force myself to both write and actually post.</p>
            <p>Not sure how you ended up here, but keep it quiet — if I get too many visitors I'll have to start paying for photo storage.</p>
          </div>
          <div class="text-textMuted text-sm mb-6 space-y-3 fr-only">
            <p>C'est mon petit coin d'internet. À côté il y a les <span class="text-neonLime/80">photos</span> dont je n'ai pas honte de partager, et en bas les <span class="text-neonLime/80">articles</span> que je me force autant à écrire qu'à publier.</p>
            <p>Je sais pas trop comment tu es arrivé ici, mais garde ça pour toi : si j'ai trop de visites je vais devoir payer le stockage des photos.</p>
          </div>
          
          <div class="flex items-center text-neonCyan font-mono text-xs group-hover:translate-x-1 transition-transform">
            <span class="pt-only">sobre mim &rarr;</span>
            <span class="en-only">about me &rarr;</span>
            <span class="fr-only">à propos &rarr;</span>
          </div>
        </div>
      </BentoBox>

      <!-- Latest Photo Box -->
      <BentoBox spanCol="col-span-4 md:col-span-2" spanRow="row-span-2" glowColor="lime" href="/photography" noPadding={true}>
        {latestPhoto && latestPhoto.data.gallery && latestPhoto.data.gallery.length > 0 ? (
          <div class="relative w-full h-full min-h-[300px] flex flex-col justify-end p-6">
            <div class="absolute inset-0 transition-all duration-500 z-0 overflow-hidden">
              <img 
                src={latestPhoto.data.gallery[0].src} 
                alt={latestPhoto.data.gallery[0].caption || latestPhoto.data.title} 
                class="w-full h-full object-cover group-hover:scale-105 transition-all duration-700"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/50 to-transparent pointer-events-none"></div>
            </div>
            
            <div class="relative z-20 pointer-events-none">
              <span class="text-xs font-mono text-neonLime mb-1 block pt-only">ÚLTIMA FOTO</span>
              <span class="text-xs font-mono text-neonLime mb-1 block en-only">LATEST PHOTO</span>
              <span class="text-xs font-mono text-neonLime mb-1 block fr-only">DERNIÈRE PHOTO</span>
              <h3 class="text-xl font-bold text-gray-100 pt-only">{latestPhoto.data.gallery[0].caption || latestPhoto.data.title}</h3>
              <h3 class="text-xl font-bold text-gray-100 en-only">{latestPhoto.data.gallery[0].captionEn || latestPhoto.data.titleEn || latestPhoto.data.title}</h3>
              <h3 class="text-xl font-bold text-gray-100 fr-only">{latestPhoto.data.gallery[0].captionFr || latestPhoto.data.titleFr || latestPhoto.data.title}</h3>
              
              <div class="flex gap-2 text-[10px] font-mono text-gray-300 mt-3 flex-wrap">
                {latestPhoto.data.date && (
                  <>
                    <span class="bg-black/50 border border-white/10 px-2 py-1 rounded pt-only">{latestPhoto.data.date.toLocaleDateString('pt-BR')}</span>
                    <span class="bg-black/50 border border-white/10 px-2 py-1 rounded en-only">{latestPhoto.data.date.toLocaleDateString('en-US')}</span>
                    <span class="bg-black/50 border border-white/10 px-2 py-1 rounded fr-only">{latestPhoto.data.date.toLocaleDateString('fr-FR')}</span>
                  </>
                )}
                {latestPhoto.data.gallery[0].camera && <span class="bg-black/50 border border-white/10 px-2 py-1 rounded">{latestPhoto.data.gallery[0].camera}</span>}
                {latestPhoto.data.gallery[0].lens && <span class="bg-black/50 border border-white/10 px-2 py-1 rounded">{latestPhoto.data.gallery[0].lens}</span>}
                {latestPhoto.data.gallery[0].aperture && <span class="bg-black/50 border border-white/10 px-2 py-1 rounded">{latestPhoto.data.gallery[0].aperture}</span>}
                {latestPhoto.data.gallery[0].iso && <span class="bg-black/50 border border-white/10 px-2 py-1 rounded">ISO {latestPhoto.data.gallery[0].iso}</span>}
                {latestPhoto.data.gallery[0].shutterSpeed && <span class="bg-black/50 border border-white/10 px-2 py-1 rounded">{latestPhoto.data.gallery[0].shutterSpeed}</span>}
              </div>
            </div>
          </div>
        ) : latestPhoto ? (
          <div class="relative w-full h-full min-h-[300px] flex flex-col justify-end p-6">
            <div class="absolute inset-0 transition-all duration-500 z-0 overflow-hidden">
              <img src={latestPhoto.data.cover} alt={latestPhoto.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-all duration-700" loading="lazy" />
              <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/50 to-transparent pointer-events-none"></div>
            </div>
            <div class="relative z-20 pointer-events-none">
              <span class="text-xs font-mono text-neonLime mb-1 block pt-only">ÚLTIMA FOTO</span>
              <span class="text-xs font-mono text-neonLime mb-1 block en-only">LATEST PHOTO</span>
              <span class="text-xs font-mono text-neonLime mb-1 block fr-only">DERNIÈRE PHOTO</span>
              <h3 class="text-xl font-bold text-gray-100 pt-only">{latestPhoto.data.title}</h3>
              <h3 class="text-xl font-bold text-gray-100 en-only">{latestPhoto.data.titleEn || latestPhoto.data.title}</h3>
              <h3 class="text-xl font-bold text-gray-100 fr-only">{latestPhoto.data.titleFr || latestPhoto.data.title}</h3>
            </div>
          </div>
        ) : (
          <div class="flex flex-col h-full justify-center items-center">
             <svg class="w-8 h-8 text-surfaceHighlight group-hover:text-neonLime transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
             <span class="text-xs font-mono text-textMuted mt-2 group-hover:text-textMain pt-only">VER GALERIA</span>
             <span class="text-xs font-mono text-textMuted mt-2 group-hover:text-textMain en-only">VIEW GALLERY</span>
             <span class="text-xs font-mono text-textMuted mt-2 group-hover:text-textMain fr-only">VOIR GALERIE</span>
          </div>
        )}
      </BentoBox>

      <!-- Latest Data Engineering Project -->
      <BentoBox spanCol="col-span-4 md:col-span-2" spanRow="row-span-1" glowColor="cyan" href="/data-engineering">
        {latestDataProject ? (
          <div class="flex flex-col h-full justify-between">
            <div>
              <span class="text-xs font-mono text-neonCyan mb-1 block pt-only">ÚLTIMO PROJETO DE ENGENHARIA DE DADOS</span>
              <span class="text-xs font-mono text-neonCyan mb-1 block en-only">LATEST DATA ENGINEERING PROJECT</span>
              <span class="text-xs font-mono text-neonCyan mb-1 block fr-only">DERNIER PROJET D'INGÉNIERIE DES DONNÉES</span>
              <h3 class="font-bold text-lg mb-2 pt-only mt-2">{latestDataProject.data.title}</h3>
              <h3 class="font-bold text-lg mb-2 en-only mt-2">{latestDataProject.data.titleEn || latestDataProject.data.title}</h3>
              <h3 class="font-bold text-lg mb-2 fr-only mt-2">{latestDataProject.data.titleFr || latestDataProject.data.title}</h3>
            </div>
            <div class="flex flex-wrap gap-2 mt-3">
              {latestDataProject.data.technologies.map((tech: string) => (
                <span class="text-[10px] font-mono border border-surfaceHighlight px-2 py-1 rounded-full text-textMuted">
                  {tech}
                </span>
              ))}
            </div>
          </div>
        ) : (
          <div class="flex flex-col h-full justify-center items-center">
             <svg class="w-8 h-8 text-surfaceHighlight group-hover:text-neonCyan transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 002-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
             <span class="text-xs font-mono text-textMuted mt-2 group-hover:text-textMain pt-only">VER PROJETOS</span>
             <span class="text-xs font-mono text-textMuted mt-2 group-hover:text-textMain en-only">VIEW PROJECTS</span>
             <span class="text-xs font-mono text-textMuted mt-2 group-hover:text-textMain fr-only">VOIR PROJETS</span>
          </div>
        )}
      </BentoBox>

      <!-- Latest DICE Review -->
      <BentoBox spanCol="col-span-2 md:col-span-1" spanRow="row-span-1" glowColor="lime" href="/dice-awards" noPadding={!!latestDice?.data?.cover} className="group overflow-hidden">
        {latestDice?.data?.cover ? (
          <div class="relative h-full w-full min-h-[150px]">
             <div class="absolute inset-0 z-0">
                <img src={latestDice.data.cover} alt={latestDice.data.game} class="w-full h-full object-cover opacity-60 group-hover:opacity-100 group-hover:scale-105 transition-all duration-700" loading="lazy" />
                <div class="absolute inset-0 bg-gradient-to-t from-base via-base/80 to-transparent pointer-events-none"></div>
             </div>
             <div class="relative z-10 p-6 flex flex-col h-full justify-between">
               <div>
                  <span class="text-xs font-mono text-neonLime mb-1 block pt-only">ÚLTIMA REVIEW</span>
                  <span class="text-xs font-mono text-neonLime mb-1 block en-only">LATEST REVIEW</span>
                  <span class="text-xs font-mono text-neonLime mb-1 block fr-only">DERNIÈRE CRITIQUE</span>
                  <h3 class="font-bold text-sm truncate text-gray-100 mt-2">{latestDice.data.game}</h3>
               </div>
               <div class="mt-4 flex items-end justify-between">
                  <span class="text-2xl font-bold text-gray-100">{latestDice.data.rating}<span class="text-xs text-gray-400">/10</span></span>
                  <span class="text-xs text-gray-300 font-mono">{latestDice.data.year}</span>
               </div>
             </div>
          </div>
        ) : latestDice ? (
          <div class="flex flex-col h-full justify-between">
            <div>
              <span class="text-xs font-mono text-neonLime mb-1 block pt-only">ÚLTIMA REVIEW</span>
              <span class="text-xs font-mono text-neonLime mb-1 block en-only">LATEST REVIEW</span>
              <span class="text-xs font-mono text-neonLime mb-1 block fr-only">DERNIÈRE CRITIQUE</span>
              <h3 class="font-bold text-sm truncate mt-2">{latestDice.data.game}</h3>
            </div>
            <div class="mt-4 flex items-end justify-between">
              <span class="text-2xl font-bold">{latestDice.data.rating}<span class="text-xs text-textMuted">/10</span></span>
              <span class="text-xs text-textMuted font-mono">{latestDice.data.year}</span>
            </div>
          </div>
        ) : (
          <div class="flex flex-col h-full justify-center items-center">
             <svg class="w-8 h-8 text-surfaceHighlight group-hover:text-neonLime transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 00-1-1H4a2 2 0 110-4h1a1 1 0 001-1V7a1 1 0 011-1h3a1 1 0 001-1V4z"></path></svg>
             <span class="text-xs font-mono text-textMuted mt-2 group-hover:text-textMain pt-only">VER REVIEWS</span>
             <span class="text-xs font-mono text-textMuted mt-2 group-hover:text-textMain en-only">VIEW REVIEWS</span>
             <span class="text-xs font-mono text-textMuted mt-2 group-hover:text-textMain fr-only">VOIR CRITIQUES</span>
          </div>
        )}
      </BentoBox>

      <!-- Academic Box -->
      <BentoBox spanCol="col-span-2 md:col-span-1" spanRow="row-span-1" glowColor="cyan" href="/academic">
        {latestAcademic ? (
          <div class="flex flex-col h-full justify-between">
            <div>
              <span class="text-xs font-mono text-neonCyan mb-1 block pt-only">ÚLTIMO ARTIGO</span>
              <span class="text-xs font-mono text-neonCyan mb-1 block en-only">LATEST POST</span>
              <span class="text-xs font-mono text-neonCyan mb-1 block fr-only">DERNIER POST</span>
              <h3 class="font-bold text-sm mb-2 mt-2 pt-only">{latestAcademic.data.title}</h3>
              <h3 class="font-bold text-sm mb-2 mt-2 en-only">{latestAcademic.data.titleEn || latestAcademic.data.title}</h3>
              <h3 class="font-bold text-sm mb-2 mt-2 fr-only">{latestAcademic.data.titleFr || latestAcademic.data.title}</h3>
            </div>
            <div class="mt-4 flex items-end justify-between">
              <span class="text-xs text-textMuted font-mono pt-only">{latestAcademic.data.semester} | {latestAcademic.data.course}</span>
              <span class="text-xs text-textMuted font-mono en-only">{latestAcademic.data.semester} | {latestAcademic.data.courseEn || latestAcademic.data.course}</span>
              <span class="text-xs text-textMuted font-mono fr-only">{latestAcademic.data.semester} | {latestAcademic.data.courseFr || latestAcademic.data.course}</span>
            </div>
          </div>
        ) : (
          <div class="flex flex-col h-full justify-center items-center">
             <svg class="w-8 h-8 text-surfaceHighlight group-hover:text-neonCyan transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5zm0 0v7"></path></svg>
             <span class="text-xs font-mono text-textMuted mt-2 group-hover:text-textMain pt-only">ACESSAR ARQUIVO</span>
             <span class="text-xs font-mono text-textMuted mt-2 group-hover:text-textMain en-only">ACCESS ARCHIVE</span>
             <span class="text-xs font-mono text-textMuted mt-2 group-hover:text-textMain fr-only">ACCÉDER AUX ARCHIVES</span>
          </div>
        )}
      </BentoBox>

    </div>
  </main>
</Layout>
