---
import Layout from '../../layouts/Layout.astro';
import BentoBox from '../../components/BentoBox.astro';
import { getCollection } from 'astro:content';

const photoEntries = await getCollection('photography');
// Ordena pelas fotos mais recentes primeiro
const sortedPhotos = photoEntries.sort((a, b) => (b.data.date?.valueOf() || 0) - (a.data.date?.valueOf() || 0));
---

<Layout title="Photography | Ramos">
  <header class="mb-12">
    <h1 class="text-4xl font-bold mb-2 pt-only">Fotografia<span class="text-neonLime">.</span></h1>
    <h1 class="text-4xl font-bold mb-2 en-only">Photography<span class="text-neonLime">.</span></h1>
    <h1 class="text-4xl font-bold mb-2 fr-only">Photographie<span class="text-neonLime">.</span></h1>
    <h1 class="text-4xl font-bold mb-2 es-only">Fotografía<span class="text-neonLime">.</span></h1>
    <h1 class="text-4xl font-bold mb-2 ja-only">写真<span class="text-neonLime">.</span></h1>
    <h1 class="text-4xl font-bold mb-2 zh-only">摄影<span class="text-neonLime">.</span></h1>
    <h1 class="text-4xl font-bold mb-2 de-only">Fotografie<span class="text-neonLime">.</span></h1>
    <h1 class="text-4xl font-bold mb-2 ru-only">Фотография<span class="text-neonLime">.</span></h1>
    <p class="text-textMuted font-mono text-sm pt-only">As fotos que eu gostei vêm parar aqui. Pelo menos as que eu quero compartilhar; algumas ficam só comigo.</p>
    <p class="text-textMuted font-mono text-sm en-only">The photos I liked end up here. At least the ones I want to share; some are just for me.</p>
    <p class="text-textMuted font-mono text-sm fr-only">Les photos que j'ai aimées finissent ici. Du moins celles que je veux partager ; certaines restent juste pour moi.</p>
    <p class="text-textMuted font-mono text-sm es-only">Las fotos que me gustaron terminan aquí. Al menos las que quiero compartir; algunas se quedan solo conmigo.</p>
    <p class="text-textMuted font-mono text-sm ja-only">気に入った写真がここにあります。少なくとも共有したいもの。いくつかは自分だけのものです。</p>
    <p class="text-textMuted font-mono text-sm zh-only">我喜欢的照片都在这里。至少是我想分享的；有些只属于我。</p>
    <p class="text-textMuted font-mono text-sm de-only">Die Fotos, die mir gefallen haben, landen hier. Zumindest die, die ich teilen möchte; einige sind nur für mich.</p>
    <p class="text-textMuted font-mono text-sm ru-only">Фотографии, которые мне понравились, попадают сюда. По крайней мере те, которыми я хочу поделиться; некоторые только для меня.</p>
  </header>

  <main>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {sortedPhotos.map(entry => (
        <BentoBox glowColor="lime" href={`/photography/${entry.slug}`} noPadding={true}>
          <div class="relative w-full h-[400px] flex flex-col justify-end p-6">
            <div class="absolute inset-0 transition-all duration-500 z-0 overflow-hidden">
              <img 
                src={entry.data.coverThumb || entry.data.cover} 
                alt={entry.data.title} 
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/50 to-transparent opacity-80 group-hover:opacity-60 transition-opacity duration-300 pointer-events-none"></div>
            </div>
            
            <div class="relative z-20 pointer-events-none">
              <h3 class="text-2xl font-bold mb-1 text-gray-100 pt-only">{entry.data.title}</h3>
              <h3 class="text-2xl font-bold mb-1 text-gray-100 en-only">{entry.data.titleEn || entry.data.title}</h3>
              <h3 class="text-2xl font-bold mb-1 text-gray-100 fr-only">{entry.data.titleFr || entry.data.title}</h3>
              <h3 class="text-2xl font-bold mb-1 text-gray-100 es-only">{entry.data.titleEs || entry.data.title}</h3>
              <h3 class="text-2xl font-bold mb-1 text-gray-100 ja-only">{entry.data.titleJa || entry.data.title}</h3>
              <h3 class="text-2xl font-bold mb-1 text-gray-100 zh-only">{entry.data.titleZh || entry.data.title}</h3>
              <h3 class="text-2xl font-bold mb-1 text-gray-100 de-only">{entry.data.titleDe || entry.data.title}</h3>
              <h3 class="text-2xl font-bold mb-1 text-gray-100 ru-only">{entry.data.titleRu || entry.data.title}</h3>
              {entry.data.date && (
                <>
                  <p class="text-xs font-mono text-neonLime mb-2 pt-only">
                    {entry.data.date.toLocaleDateString('pt-BR')}
                  </p>
                  <p class="text-xs font-mono text-neonLime mb-2 en-only">
                    {entry.data.date.toLocaleDateString('en-US')}
                  </p>
                  <p class="text-xs font-mono text-neonLime mb-2 fr-only">
                    {entry.data.date.toLocaleDateString('fr-FR')}
                  </p>
                  <p class="text-xs font-mono text-neonLime mb-2 es-only">
                    {entry.data.date.toLocaleDateString('es-ES')}
                  </p>
                  <p class="text-xs font-mono text-neonLime mb-2 ja-only">
                    {entry.data.date.toLocaleDateString('ja-JP')}
                  </p>
                  <p class="text-xs font-mono text-neonLime mb-2 zh-only">
                    {entry.data.date.toLocaleDateString('zh-CN')}
                  </p>
                  <p class="text-xs font-mono text-neonLime mb-2 de-only">
                    {entry.data.date.toLocaleDateString('de-DE')}
                  </p>
                  <p class="text-xs font-mono text-neonLime mb-2 ru-only">
                    {entry.data.date.toLocaleDateString('ru-RU')}
                  </p>
                </>
              )}
            </div>
          </div>
        </BentoBox>
      ))}
    </div>
  </main>
</Layout>
