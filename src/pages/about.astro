            {[
              { lang: 'Português', level: { pt: 'Nativo', en: 'Native', fr: 'Langue maternelle' }, pct: 100, color: 'from-neonCyan to-neonLime' },
              { lang: 'Inglês / English', level: { pt: 'Avançado', en: 'Advanced', fr: 'Avancé' }, pct: 88, color: 'from-neonCyan to-neonLime' },
              { lang: 'Français', level: { pt: 'Avançado', en: 'Advanced', fr: 'Avancé' }, pct: 80, color: 'from-neonCyan to-neonLime' },
            ].map((l) => (
              <div class="bg-surface border border-surfaceHighlight rounded-2xl p-4">
                <div class="flex justify-between items-center mb-2">
                  <span class="font-mono text-sm font-bold">{l.lang}</span>
                  <span class="font-mono text-xs text-textMuted pt-only">{l.level.pt}</span>
                  <span class="font-mono text-xs text-textMuted en-only">{l.level.en}</span>
                  <span class="font-mono text-xs text-textMuted fr-only">{l.level.fr}</span>
                </div>
                <div class="h-1 bg-surfaceHighlight rounded-full overflow-hidden">
                  <div class={`h-full bg-gradient-to-r ${l.color} rounded-full`} style={`width: ${l.pct}%`}></div>
                </div>
              </div>
            ))}
          </div>
        </section>
      </div>
    </div>

    <!-- Recomendação -->
    <section class="mb-8">
      <h2 class="text-xs font-mono tracking-widest text-neonCyan mb-6 pt-only">// RECOMENDAÇÃO</h2>
      <h2 class="text-xs font-mono tracking-widest text-neonCyan mb-6 en-only">// RECOMMENDATION</h2>
      <h2 class="text-xs font-mono tracking-widest text-neonCyan mb-6 fr-only">// RECOMMANDATION</h2>

      <blockquote class="bg-surface border border-surfaceHighlight rounded-2xl p-6 relative">
        <span class="absolute top-4 left-5 text-5xl text-neonLime leading-none opacity-40 font-serif select-none">"</span>
        <p class="text-textMuted leading-relaxed pl-6 italic">Lucas é um profissional excelente! Sendo criativo e altamente qualificado tecnicamente, é com certeza um valioso quadro para qualquer empresa. Adorei trabalhar com o Lucas e o recomendo fortemente.</p>
        <footer class="mt-4 pl-6 flex items-center gap-3">
          <div class="w-8 h-8 rounded-full bg-surfaceHighlight flex items-center justify-center font-mono text-xs font-bold text-neonCyan">AR</div>
          <div>
            <p class="font-bold text-sm">André Ribeiro</p>
            <p class="font-mono text-xs text-textMuted">Data Chapter Lead · Business Intelligence & Data Warehousing</p>
          </div>
        </footer>
      </blockquote>
    </section>

  </article>
</Layout>
