---
import Layout from '../../layouts/Layout.astro';
import BentoBox from '../../components/BentoBox.astro';
import { getCollection } from 'astro:content';

const entries = await getCollection('data-engineering');
---

<Layout title="Data Engineering | Lucas Ramos">
  <header class="mb-12">
    <h1 class="text-4xl font-bold mb-2 pt-only">Engenharia de Dados<span class="text-neonCyan">.</span></h1>
    <h1 class="text-4xl font-bold mb-2 en-only">Data Engineering<span class="text-neonCyan">.</span></h1>
    <h1 class="text-4xl font-bold mb-2 fr-only">Ingénierie des Données<span class="text-neonCyan">.</span></h1>
    <p class="text-textMuted font-mono text-sm pt-only">Pipelines, automação e arquitetura de dados em larga escala. Chato, eu sei, mas alguém tem que fazer.</p>
    <p class="text-textMuted font-mono text-sm en-only">Pipelines, automation, and large-scale data architecture. Boring, I know, but someone's gotta do it.</p>
    <p class="text-textMuted font-mono text-sm fr-only">Pipelines, automatisation et architecture de données à grande échelle. Ennuyeux, je sais, mais quelqu'un doit le faire.</p>
  </header>

  <main>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {entries.map(entry => (
        <BentoBox glowColor="cyan" href={`/data-engineering/${entry.slug}`}>
          <div class="flex flex-col h-full justify-between">
            <div>
              <span class="text-xs font-mono text-neonCyan mb-2 block pt-only">{entry.data.date.toLocaleDateString('pt-BR')}</span>
              <span class="text-xs font-mono text-neonCyan mb-2 block en-only">{entry.data.date.toLocaleDateString('en-US')}</span>
              <span class="text-xs font-mono text-neonCyan mb-2 block fr-only">{entry.data.date.toLocaleDateString('fr-FR')}</span>
              <h3 class="font-bold text-xl mb-4 pt-only">{entry.data.title}</h3>
              <h3 class="font-bold text-xl mb-4 en-only">{entry.data.titleEn || entry.data.title}</h3>
              <h3 class="font-bold text-xl mb-4 fr-only">{entry.data.titleFr || entry.data.title}</h3>
              <div class="flex flex-wrap gap-2">
                {entry.data.technologies.map((tech: string) => (
                  <span class="text-[10px] font-mono border border-surfaceHighlight px-2 py-1 rounded-full text-textMuted">{tech}</span>
                ))}
              </div>
            </div>
          </div>
        </BentoBox>
      ))}
    </div>
  </main>
</Layout>
