---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const entries = await getCollection('data-engineering');
  return entries.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<Layout title={`${entry.data.title} | Lucas Ramos`}>
  <article class="max-w-4xl mx-auto py-8">
    <a href="/data-engineering" class="text-neonCyan font-mono text-xs hover:underline mb-8 inline-block pt-only">&lt; VOLTAR PARA ENGENHARIA DE DADOS</a>
    <a href="/data-engineering" class="text-neonCyan font-mono text-xs hover:underline mb-8 inline-block en-only">&lt; BACK TO DATA ENGINEERING</a>
    <a href="/data-engineering" class="text-neonCyan font-mono text-xs hover:underline mb-8 inline-block fr-only">&lt; RETOUR À L'INGÉNIERIE DES DONNÉES</a>
    
    <header class="mb-12 border-b border-surfaceHighlight pb-8">
      <span class="text-neonCyan font-mono text-sm block mb-4 pt-only">{entry.data.date.toLocaleDateString('pt-BR')}</span>
      <span class="text-neonCyan font-mono text-sm block mb-4 en-only">{entry.data.date.toLocaleDateString('en-US')}</span>
      <span class="text-neonCyan font-mono text-sm block mb-4 fr-only">{entry.data.date.toLocaleDateString('fr-FR')}</span>
      <h1 class="text-4xl font-bold mb-6 pt-only">{entry.data.title}</h1>
      <h1 class="text-4xl font-bold mb-6 en-only">{entry.data.titleEn || entry.data.title}</h1>
      <h1 class="text-4xl font-bold mb-6 fr-only">{entry.data.titleFr || entry.data.title}</h1>
      
      <div class="flex flex-wrap gap-3 mb-6">
        {entry.data.technologies.map((tech: string) => (
          <span class="text-sm font-mono bg-surfaceHighlight px-3 py-1 rounded text-textMain">{tech}</span>
        ))}
      </div>

      {entry.data.repoUrl && (
        <a href={entry.data.repoUrl} target="_blank" class="text-neonCyan font-mono text-sm hover:underline flex items-center gap-2 mt-4">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"></path></svg>
          <span class="pt-only">VER NO GITHUB</span>
          <span class="en-only">VIEW ON GITHUB</span>
          <span class="fr-only">VOIR SUR GITHUB</span>
        </a>
      )}
    </header>

    <div class="text-textMuted leading-relaxed space-y-6 [&>p]:mb-4 [&_pre]:p-6 [&_pre]:rounded-2xl [&_pre]:overflow-x-auto [&_pre]:border [&_pre]:border-surfaceHighlight [&_code]:font-mono [&_code]:text-sm">
      <Content />
    </div>
  </article>
</Layout>
